# ── Supabase ──
# Projectinstellingen vanuit het Supabase-dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── NextAuth v5 ──
# AUTH_SECRET genereren met: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# ── Google OAuth ──
# Aanmaken via Google Cloud Console → APIs & Services → Credentials
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Optional: Apple OAuth ──
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=

# ── WhatsApp / Twilio (sandbox) ──
# Accountgegevens via console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
NEXT_PUBLIC_WHATSAPP_NUMBER=14155238886
# Join code voor Twilio Sandbox (bijv. "join busy-tiger"). Leeg = "Hoi" als standaardbericht.
NEXT_PUBLIC_WHATSAPP_JOIN_CODE=

# ── WhatsApp / Meta Cloud API (productie) ──
# Als WHATSAPP_TOKEN + WHATSAPP_PHONE_ID zijn ingesteld, wordt Meta API gebruikt i.p.v. Twilio
# Setup: /admin/whatsapp
WHATSAPP_TOKEN=EAAxxxxx...
WHATSAPP_PHONE_ID=123456789...
WEBHOOK_VERIFY_TOKEN=dva_2026

# ── Anthropic / Claude AI ──
# API-sleutel voor het uitlezen van verzekeringspolissen en energierekeningen via Claude
ANTHROPIC_API_KEY=sk-ant-...

# ── Cron jobs ──
# Geheime sleutel om de dagelijkse cron-endpoints te beveiligen tegen onbevoegde aanroepen
# Vercel stelt deze automatisch in als je cron jobs activeert (Settings → Cron Jobs)
CRON_SECRET=your-cron-secret

# ── Ollama (lokale PII-anonimisering) ──
# Lokaal draaiende Ollama-instantie voor het anonimiseren van persoonsgegevens in PDF's
# vóórdat ze naar de Claude API worden verstuurd. Standaard: http://localhost:11434
OLLAMA_URL=http://localhost:11434
# Het te gebruiken Ollama-model voor PII-detectie. Standaard: llama3.2
OLLAMA_MODEL=llama3.2

# ── Daisycon (affiliate tracking) ──
# Inloggegevens voor de Daisycon affiliate API (te vinden in het Daisycon publisher-dashboard)
DAISYCON_CLIENT_ID=your-daisycon-client-id
DAISYCON_CLIENT_SECRET=your-daisycon-client-secret
# Jouw publisher-ID in het Daisycon-netwerk
DAISYCON_PUBLISHER_ID=your-daisycon-publisher-id
# Zet op "false" om de live productie-API te gebruiken. Standaard: true (sandbox)
DAISYCON_USE_SANDBOX=true

# ── Feature flags ──
# Zet op "true" om live Playwright-scrapers in te schakelen op de analysepagina (langzaam, alleen lokaal)
NEXT_PUBLIC_ENABLE_LIVE_SCRAPERS=false
# Zet op "true" om het uploaden van afbeeldingen (JPG/PNG) toe te staan naast PDF's
# Let op: afbeeldingen worden NIET lokaal geanonimiseerd vóór verzending naar Claude
ALLOW_IMAGE_UPLOADS=false
